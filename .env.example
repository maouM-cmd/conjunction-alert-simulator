# Space-Track (optional) — register at https://www.space-track.org/auth/createAccount
SPACE_TRACK_USER=
SPACE_TRACK_PASSWORD=

# TLE catalog provider: celestrak | spacetrack
TLE_PROVIDER=celestrak

# Space-Track CDM fetch (Phase 4B) uses the same credentials as TLE_PROVIDER=spacetrack

# Scale-out (Phase 9D)
FLEET_MAX_SATELLITES=10000
SCREENING_CHUNK_SIZE=50
SCREENING_MAX_WORKERS=2
CELERY_WORKER_CONCURRENCY=2

# Docker / production (Phase 4C)
CAS_HOST=0.0.0.0
CAS_PORT=8000
# BATCH_MAX_WORKERS=2  # batch 並列ワーカー数（Render/Fly では 2 推奨。README / deploy.md 参照）

# Production hardening (Phase 9E)
# CAS_API_KEY_REQUIRED=false
# CAS_ADMIN_API_KEY=
# AUDIT_LOG_RETENTION_DAYS=90
# SLA_SCREENING_MAX_LAG_HOURS=24
# SLA_API_TARGET_PERCENT=99.9
# SLA_API_ROLLING_WINDOW_HOURS=720
# SLA_API_PERSIST_ENABLED=false
# SLA_API_RETENTION_DAYS=90

# TLE RTN covariance propagation (Phase 10K)
# COV_PROPAGATION_ENABLED=false
# COV_PROP_R_GROWTH_PER_DAY=0.10
# COV_PROP_T_GROWTH_PER_DAY=0.05
# COV_PROP_N_GROWTH_PER_DAY=0.05

# CDM encounter covariance at CDM TCA (Phase 10M)
# CDM_TCA_SHIFT_ENABLED=false

# Fleet-scoped API SLO (Phase 10N)
# SLA_FLEET_API_SLO_ENABLED=false

# Per-fleet alert Prometheus metrics (Phase 10Q)
# FLEET_ALERT_METRICS_ENABLED=false
# FLEET_ALERT_OPEN_THRESHOLD=10
# FLEET_ALERT_HIGH_RISK_THRESHOLD=1

# Alertmanager push on fleet breach (Phase 10S)
# ALERTMANAGER_PUSH_ENABLED=false
# ALERTMANAGER_URL=http://alertmanager:9093
# ALERTMANAGER_BASIC_AUTH_USER=
# ALERTMANAGER_BASIC_AUTH_PASSWORD=

# Alert state machine (Phase 10R / 10T)
# ALERT_STM_AUTO_ESCALATE_STATUS=false
# ALERT_STM_REOPEN_TO_OPEN_ENABLED=false

# Alertmanager silences (Phase 10T)
# ALERTMANAGER_SILENCES_ENABLED=false
# ALERTMANAGER_SILENCE_DEFAULT_HOURS=4

# Alertmanager automation (Phase 10U)
# ALERTMANAGER_PUSH_CELERY_ENABLED=false
# ALERTMANAGER_PUSH_CELERY_INTERVAL_SEC=60
# ALERTMANAGER_AUTO_SILENCE_ON_TRIAGE_ENABLED=false
# ALERTMANAGER_AUTO_SILENCE_HOURS=4

# Redis shared breach state (Phase 10V)
# ALERTMANAGER_PUSH_REDIS_STATE_ENABLED=false

# OIDC SSO for Ops UI (Phase 10I)
# OPS_OIDC_ENABLED=false
# OPS_OIDC_ISSUER=https://your-idp.example.com
# OPS_OIDC_CLIENT_ID=
# OPS_OIDC_CLIENT_SECRET=
# OPS_OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/oidc/callback
# OPS_OIDC_ADMIN_EMAILS=admin@example.com
# OPS_OIDC_FLEET_MAPPINGS={"fleet-uuid":["ops@example.com"]}
# OPS_SESSION_SECRET=
# OPS_SESSION_TTL_HOURS=8

# Fleet registry (Phase 9A) — optional; unset disables /api/v1/fleets (503)
# DATABASE_URL=postgresql://cas:cas@localhost:5432/cas

# Scheduled screening (Phase 9B) — optional; unset disables /api/v1/screening (503)
# REDIS_URL=redis://localhost:6379/0

# Webhook alerts (Phase 4B-Ext / 5C / 7B)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# ALERT_WEBHOOK_FORMAT=generic | slack | slack_bot | smtp | pagerduty
# slack_bot 時は ALERT_WEBHOOK_URL 不要:
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0123456789
# smtp 時は ALERT_WEBHOOK_URL 不要:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=cas@example.com
# SMTP_TO=ops@example.com
# SMTP_USER=cas@example.com
# SMTP_PASSWORD=secret
# SMTP_USE_TLS=true
# pagerduty 時は ALERT_WEBHOOK_URL 不要:
# PAGERDUTY_ROUTING_KEY=
# PAGERDUTY_LIFECYCLE_ENABLED=false
# PAGERDUTY_INBOUND_SYNC_ENABLED=false
# PAGERDUTY_WEBHOOK_SIGNING_SECRET=
# ALERT_PC_THRESHOLD=0.00001
